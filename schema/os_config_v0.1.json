{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "os_config_v0.1",
  "title": "OS Config",
  "description": "Personalized operating system configuration generated by the OS Generator",
  "type": "object",
  "required": ["schema_version", "user", "buckets", "workflow_description", "tone", "generated_at"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "user": {
      "type": "object",
      "required": ["name", "bazi_element", "archetype", "archetype_descriptor"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bazi_element": {
          "type": "string",
          "enum": ["Metal", "Wood", "Water", "Fire", "Earth"]
        },
        "archetype": {
          "type": "string",
          "minLength": 1
        },
        "archetype_descriptor": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "buckets": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["id", "label", "description", "archetype_focus", "initial_projects"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "enum": ["BUILD", "FIX", "IMPROVE", "OPERATE", "THINK", "PERSONAL"]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "archetype_focus": {
            "type": "string",
            "minLength": 1
          },
          "initial_projects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "tone": {
      "type": "string",
      "minLength": 1
    },
    "workflow_description": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "energy_hours": {
      "type": ["object", "null"],
      "properties": {
        "peak_windows": {
          "type": "array",
          "items": { "type": "string" }
        },
        "flexibility": {
          "type": "string",
          "enum": ["flexible", "moderate", "structured"]
        },
        "user_adjustable": {
          "type": "boolean"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
